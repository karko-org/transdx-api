generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// 1. Operations Layer
// ============================================================

model Workshop {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  address    String?  @db.VarChar(200)
  phone      String?  @db.VarChar(20)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users User[]
  cases Case[]

  @@map("workshops")
}

model User {
  id            Int      @id @default(autoincrement())
  workshop_id   Int
  username      String   @unique @db.VarChar(50)
  password_hash String   @db.VarChar(200)
  name          String   @db.VarChar(50)
  role          String   @default("counselor") @db.VarChar(20) // admin | manager | counselor
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  workshop Workshop @relation(fields: [workshop_id], references: [id])
  cases    Case[]

  @@map("users")
}

model Vehicle {
  id             Int      @id @default(autoincrement())
  plate_number   String   @unique @db.VarChar(20)
  customer_name  String?  @db.VarChar(50)
  customer_phone String?  @db.VarChar(20)
  manufacturer   String?  @db.VarChar(50)
  model          String?  @db.VarChar(50)
  year           Int?
  transmission   String?  @db.VarChar(50)
  memo           String?  @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  cases Case[]

  @@map("vehicles")
}

// ============================================================
// 2. Diagnostic Master Layer
// ============================================================

model SymptomCategory {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  symptoms Symptom[]

  @@map("symptom_categories")
}

model Symptom {
  id          Int      @id @default(autoincrement())
  category_id Int
  name        String   @db.VarChar(100)
  description String?  @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category          SymptomCategory   @relation(fields: [category_id], references: [id])
  symptom_questions SymptomQuestion[]
  case_symptoms     CaseSymptom[]

  @@map("symptoms")
}

model FailureType {
  id           Int      @id @default(autoincrement())
  code         String   @unique @db.VarChar(20)
  display_name String   @db.VarChar(100)
  description  String?  @db.Text
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  diagnosis_rules         DiagnosisRule[]
  repair_estimate_items   RepairEstimateItem[]
  diagnosis_run_candidates DiagnosisRunCandidate[]
  diagnosis_run_selections DiagnosisRun[] 

  @@map("failure_types")
}

model Question {
  id              Int      @id @default(autoincrement())
  code            String   @unique @db.VarChar(20)
  text            String   @db.VarChar(300)
  question_intent String?  @db.VarChar(200)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  symptom_questions     SymptomQuestion[]
  diagnosis_rules       DiagnosisRule[]
  case_question_answers CaseQuestionAnswer[]

  @@map("questions")
}

model SymptomQuestion {
  id          Int @id @default(autoincrement())
  symptom_id  Int
  question_id Int

  symptom  Symptom  @relation(fields: [symptom_id], references: [id], onDelete: Cascade)
  question Question @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@unique([symptom_id, question_id])
  @@map("symptom_questions")
}

model DiagnosisRule {
  id              Int      @id @default(autoincrement())
  failure_type_id Int
  question_id     Int
  expected_answer Boolean
  score_delta     Int      @default(0)
  explanation     String?  @db.Text
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  failure_type FailureType @relation(fields: [failure_type_id], references: [id])
  question     Question    @relation(fields: [question_id], references: [id])

  @@map("diagnosis_rules")
}


// 임시 테이블
model RepairEstimateItem {
  id              Int      @id @default(autoincrement())
  failure_type_id Int
  item_name       String   @db.VarChar(100)
  item_type       String   @default("part") @db.VarChar(20)
  unit_price      Int      @default(0)
  quantity        Int      @default(1)
  description     String?  @db.Text
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  failure_type FailureType @relation(fields: [failure_type_id], references: [id])

  @@map("repair_estimate_items")
}

// ============================================================
// 3. Runtime Layer
// ============================================================

model Case {
  id          Int      @id @default(autoincrement())
  workshop_id Int
  user_id     Int
  vehicle_id  Int
  status      String   @default("draft") @db.VarChar(20) // draft → diagnosed → quoted → completed
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  workshop Workshop @relation(fields: [workshop_id], references: [id])
  user     User     @relation(fields: [user_id], references: [id])
  vehicle  Vehicle  @relation(fields: [vehicle_id], references: [id])

  case_symptoms         CaseSymptom[]
  case_question_answers CaseQuestionAnswer[]
  diagnosis_runs        DiagnosisRun[]
  quotes                Quote[]
  snapshots             Snapshot[]

  @@map("cases")
}

model CaseSymptom {
  id         Int @id @default(autoincrement())
  case_id    Int
  symptom_id Int

  case_rel Case    @relation(fields: [case_id], references: [id], onDelete: Cascade)
  symptom  Symptom @relation(fields: [symptom_id], references: [id])

  @@unique([case_id, symptom_id])
  @@map("case_symptoms")
}

model CaseQuestionAnswer {
  id          Int     @id @default(autoincrement())
  case_id     Int
  question_id Int
  answer      Boolean

  case_rel Case     @relation(fields: [case_id], references: [id], onDelete: Cascade)
  question Question @relation(fields: [question_id], references: [id])

  @@unique([case_id, question_id])
  @@map("case_question_answers")
}

model DiagnosisRun {
  id                       Int      @id @default(autoincrement())
  case_id                  Int
  run_version              Int      @default(1)
  selected_failure_type_id Int?
  created_at               DateTime @default(now())

  case_rel   Case                    @relation(fields: [case_id], references: [id], onDelete: Cascade)
  candidates DiagnosisRunCandidate[]
  selected_failure_type FailureType? @relation(fields: [selected_failure_type_id], references: [id], onDelete: SetNull)


  @@unique([case_id, run_version])
  @@map("diagnosis_runs")
}

model DiagnosisRunCandidate {
  id               Int   @id @default(autoincrement())
  diagnosis_run_id Int
  failure_type_id  Int
  score            Float
  rank             Int   // 1 | 2 | 3

  diagnosis_run DiagnosisRun @relation(fields: [diagnosis_run_id], references: [id], onDelete: Cascade)
  failure_type  FailureType  @relation(fields: [failure_type_id], references: [id])

  @@map("diagnosis_run_candidates")
}

model Quote {
  id      Int  @id @default(autoincrement())
  case_id Int
  items      Json
  total      Int      @default(0)
  memo       String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  case_rel Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@map("quotes")
}

model Snapshot {
  id             Int      @id @default(autoincrement())
  case_id        Int
  snapshot_type  String   @db.VarChar(30)
  data                Json
  actual_failure_type String?  @db.VarChar(100)
  work_description    String?  @db.Text
  final_charge        Int?
  is_rework           Boolean  @default(false)
  created_at          DateTime @default(now())

  case_rel Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@map("snapshots")
}